<h2 style="color: #0f172a; font-size: 22px; margin: 0 0 4px 0; font-weight: 600;">New Client Feedback</h2>
<p style="color: #64748b; font-size: 14px; margin: 0 0 24px 0;">A client submitted feedback and it's waiting for your review.</p>

<table width="100%" cellpadding="0" cellspacing="0" style="background-color: #f8fafc; border-radius: 8px; margin-bottom: 24px;">
  <tr>
    <td style="padding: 24px;">
      <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <td style="padding-bottom: 12px;">
            <strong style="color: #0f172a; font-size: 16px;"><%= @testimonial.name %></strong>
            <% if @testimonial.title.present? || @testimonial.company.present? %>
              <br><span style="color: #64748b; font-size: 14px;"><%= [@testimonial.title, @testimonial.company].compact_blank.join(', ') %></span>
            <% end %>
          </td>
        </tr>
        <tr>
          <td style="padding-bottom: 16px;">
            <% @testimonial.rating.times do %><span style="color: #f59e0b; font-size: 18px;">&#9733;</span><% end %><% (5 - @testimonial.rating).times do %><span style="color: #e2e8f0; font-size: 18px;">&#9733;</span><% end %>
          </td>
        </tr>
        <tr>
          <td style="border-left: 3px solid #dc2626; padding-left: 16px;">
            <p style="margin: 0; color: #475569; font-size: 14px; font-style: italic; line-height: 1.6;"><%= @testimonial.blurb %></p>
          </td>
        </tr>
      </table>

      <% if @testimonial.project_type.present? %>
        <p style="margin: 16px 0 0 0; font-size: 14px;">
          <strong style="color: #0f172a;">What we did:</strong> <span style="color: #475569;"><%= @testimonial.project_type %></span>
        </p>
      <% end %>

      <% if @testimonial.website_url.present? %>
        <p style="margin: 8px 0 0 0; font-size: 14px;">
          <strong style="color: #0f172a;">Project:</strong> <a href="<%= @testimonial.website_url %>" style="color: #dc2626; text-decoration: none;"><%= @testimonial.website_url %></a>
        </p>
      <% end %>

      <% if @testimonial.photos.attached? %>
        <p style="margin: 8px 0 0 0; font-size: 14px; color: #64748b;">
          <%= @testimonial.photos.count %> photo(s) attached
        </p>
      <% end %>
    </td>
  </tr>
</table>

<p style="font-size: 14px; color: #64748b; margin: 0 0 16px 0;">
  This feedback is <strong>hidden by default</strong> and needs your approval to go live.
</p>

<p style="font-size: 14px; margin: 0;">
  <a href="<%= admin_dashboard_url(tab: 'testimonials') %>" style="display: inline-block; background-color: #0f172a; color: #ffffff; text-decoration: none; padding: 10px 20px; border-radius: 6px; font-size: 14px; font-weight: 500;">Review &amp; Approve</a>
</p>
