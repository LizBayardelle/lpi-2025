<% testimonials = local_assigns[:testimonials] || Testimonial.visible.ordered.limit(6) %>
<% return if testimonials.empty? %>

<section class="section-padding bg-slate-50">
  <div class="container-custom px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center mb-12">
      <h2 class="font-display text-3xl md:text-5xl font-light text-slate-900 tracking-tight mb-4 animate-on-scroll">
        What our clients say
      </h2>
      <p class="text-slate-600 text-lg animate-on-scroll">
        Real feedback from the people we've worked with.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      <% testimonials.each do |testimonial| %>
        <div class="bg-white rounded-xl p-8 shadow-sm hover:shadow-md transition-shadow duration-300 flex flex-col animate-on-scroll">
          <!-- Photos -->
          <% if testimonial.photos.attached? %>
            <div class="flex flex-wrap gap-2 mb-4">
              <% testimonial.photos.each do |photo| %>
                <div class="w-16 h-16 rounded-lg shadow-md">
                  <%= image_tag photo.variant(resize_to_fill: [128, 128]), class: "w-full h-full object-cover rounded-lg", alt: "" %>
                </div>
              <% end %>
            </div>
          <% end %>

          <!-- Stars -->
          <div class="flex items-center gap-0.5 mb-4">
            <% 5.times do |i| %>
              <svg class="w-5 h-5 <%= i < testimonial.rating ? 'text-amber-400' : 'text-slate-200' %>" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            <% end %>
          </div>

          <!-- Blurb -->
          <blockquote class="border-l-2 border-red-600/30 pl-4 text-slate-600 leading-relaxed italic mb-6 flex-1">
            <%= testimonial.blurb %>
          </blockquote>

          <!-- Attribution -->
          <div class="border-t border-slate-100 pt-4">
            <p class="font-medium text-slate-900 leading-tight"><%= testimonial.name %></p>
            <% if testimonial.title.present? || testimonial.company.present? %>
              <p class="text-sm text-slate-500 leading-tight mt-0.5">
                <%= [testimonial.title, testimonial.company].compact_blank.join(', ') %>
              </p>
            <% end %>
            <% if testimonial.website_url.present? %>
              <a href="<%= testimonial.website_url %>" target="_blank" rel="noopener" class="text-sm text-red-600 hover:text-red-800 transition-colors inline-flex items-center gap-1 mt-1">
                View project
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
