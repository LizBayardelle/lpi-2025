<% content_for :title, "Create Account - Linchpin Industries" %>
<% content_for :show_navbar, 'false' %>

<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full">
    <!-- Header -->
    <div class="text-center mb-8">
      <%= link_to root_path, class: "inline-block mb-6" do %>
        <span class="font-display text-3xl font-medium text-slate-900 tracking-tight">Linchpin Industries</span>
      <% end %>
      <h2 class="font-display text-2xl font-light text-slate-900 mb-2">
        Create your account
      </h2>
      <p class="text-slate-600">
        Get started with Linchpin Industries
      </p>
    </div>

    <!-- Sign Up Form -->
    <div class="bg-white rounded-xl shadow-lg p-8">
      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
        <% if resource.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3">
            <p class="text-red-800 text-sm font-medium mb-2">Please fix the following:</p>
            <ul class="list-disc list-inside text-red-700 text-sm space-y-1">
              <% resource.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.input :first_name,
                        required: false,
                        autofocus: true,
                        label: "First Name",
                        input_html: {
                          autocomplete: "given-name",
                          class: "w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all duration-200 text-slate-900"
                        },
                        label_html: { class: "block text-sm font-medium text-slate-700 mb-2" },
                        wrapper_html: { class: "mb-0" } %>
          </div>
          <div>
            <%= f.input :last_name,
                        required: false,
                        label: "Last Name",
                        input_html: {
                          autocomplete: "family-name",
                          class: "w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all duration-200 text-slate-900"
                        },
                        label_html: { class: "block text-sm font-medium text-slate-700 mb-2" },
                        wrapper_html: { class: "mb-0" } %>
          </div>
        </div>

        <div>
          <%= f.input :email,
                      required: true,
                      label: "Email Address",
                      input_html: {
                        autocomplete: "email",
                        class: "w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all duration-200 text-slate-900"
                      },
                      label_html: { class: "block text-sm font-medium text-slate-700 mb-2" },
                      wrapper_html: { class: "mb-0" },
                      error_html: { class: "text-red-600 text-sm mt-1" } %>
        </div>

        <div>
          <%= f.input :password,
                      required: true,
                      label: "Password",
                      hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length),
                      input_html: {
                        autocomplete: "new-password",
                        class: "w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all duration-200 text-slate-900"
                      },
                      label_html: { class: "block text-sm font-medium text-slate-700 mb-2" },
                      wrapper_html: { class: "mb-0" },
                      hint_html: { class: "text-slate-500 text-xs mt-1" },
                      error_html: { class: "text-red-600 text-sm mt-1" } %>
        </div>

        <div>
          <%= f.input :password_confirmation,
                      required: true,
                      label: "Confirm Password",
                      input_html: {
                        autocomplete: "new-password",
                        class: "w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all duration-200 text-slate-900"
                      },
                      label_html: { class: "block text-sm font-medium text-slate-700 mb-2" },
                      wrapper_html: { class: "mb-0" },
                      error_html: { class: "text-red-600 text-sm mt-1" } %>
        </div>

        <div>
          <%= f.button :submit, "Create Account", class: "w-full btn-primary py-3 text-base font-medium" %>
        </div>
      <% end %>

      <!-- Links -->
      <div class="mt-6 text-center space-y-3">
        <p class="text-sm text-slate-600">
          Already have an account?
          <%= link_to "Sign in", new_session_path(resource_name), class: "font-medium text-slate-900 hover:underline transition-colors" %>
        </p>
      </div>
    </div>

    <!-- Back to Home -->
    <div class="text-center mt-8">
      <%= link_to "← Back to Home", root_path, class: "text-slate-600 hover:text-slate-900 transition-colors text-sm" %>
    </div>
  </div>
</div>
