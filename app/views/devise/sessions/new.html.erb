<% content_for :title, "Sign In - Linchpin Industries" %>
<% content_for :show_navbar, 'false' %>

<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full">
    <!-- Header -->
    <div class="text-center mb-8">
      <%= link_to root_path, class: "inline-block mb-6" do %>
        <span class="font-display text-3xl font-medium text-slate-900 tracking-tight">Linchpin Industries</span>
      <% end %>
      <h2 class="font-display text-2xl font-light text-slate-900 mb-2">
        Welcome back
      </h2>
      <p class="text-slate-600">
        Sign in to access your dashboard
      </p>
    </div>

    <!-- Sign In Form -->
    <div class="bg-white rounded-xl shadow-lg p-8">
      <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
        <div>
          <%= f.input :email,
                      required: false,
                      autofocus: true,
                      label: "Email Address",
                      input_html: { 
                        autocomplete: "email",
                        class: "w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all duration-200 text-slate-900"
                      },
                      label_html: { class: "block text-sm font-medium text-slate-700 mb-2" },
                      wrapper_html: { class: "mb-0" },
                      error_html: { class: "text-red-600 text-sm mt-1" } %>
        </div>

        <div>
          <%= f.input :password,
                      required: false,
                      label: "Password",
                      input_html: { 
                        autocomplete: "current-password",
                        class: "w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all duration-200 text-slate-900"
                      },
                      label_html: { class: "block text-sm font-medium text-slate-700 mb-2" },
                      wrapper_html: { class: "mb-0" },
                      error_html: { class: "text-red-600 text-sm mt-1" } %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-3">
            <label class="relative inline-flex items-center cursor-pointer">
              <%= f.check_box :remember_me, class: "sr-only peer" %>
              <div class="w-9 h-5 bg-slate-200 rounded-full peer peer-checked:bg-slate-900 peer-focus:ring-2 peer-focus:ring-slate-900/20 transition-colors duration-200 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:shadow-sm after:transition-all after:duration-200 peer-checked:after:translate-x-full"></div>
            </label>
            <span class="text-sm text-slate-700 select-none">Remember me</span>
          </div>
        <% end %>

        <div>
          <%= f.button :submit, "Sign In", class: "w-full btn-primary py-3 text-base font-medium" %>
        </div>
      <% end %>

      <!-- Links -->
      <div class="mt-6 text-center space-y-3">
        <p class="text-sm text-slate-600">
          Don't have an account?
          <%= link_to "Create one", new_registration_path(resource_name), class: "font-medium text-slate-900 hover:underline transition-colors" %>
        </p>
        <p class="text-sm">
          <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-slate-600 hover:text-slate-900 transition-colors" %>
        </p>
      </div>
    </div>

    <!-- Back to Home -->
    <div class="text-center mt-8">
      <%= link_to "← Back to Home", root_path, class: "text-slate-600 hover:text-slate-900 transition-colors text-sm" %>
    </div>
  </div>
</div>