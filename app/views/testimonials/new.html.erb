<% content_for :title, "How Did We Do? - Linchpin Industries" %>
<% content_for :meta_description, "Tell us about your experience working with Linchpin Industries. Your feedback helps us grow and helps others find the right partner." %>

<div class="min-h-screen bg-white">
  <!-- Hero Section -->
  <section class="relative bg-slate-900 text-white py-32 md:py-40">
    <div class="container-custom px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="font-display text-4xl md:text-6xl font-light leading-tight tracking-tight mb-6 animate-on-scroll">
          How did we <span class="italic">do?</span>
        </h1>
        <p class="text-xl text-slate-300 mb-8 animate-on-scroll leading-relaxed max-w-3xl mx-auto">
          We'd love to hear about your experience working with us. Your honest feedback means the world and helps future clients know what to expect.
        </p>
      </div>
    </div>
  </section>

  <!-- Feedback Form -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <div class="bg-slate-50 rounded-xl p-8 md:p-12">
          <div class="text-center mb-8">
            <h2 class="font-display text-3xl font-light text-slate-900 mb-4 tracking-tight">
              Tell us about your experience
            </h2>
            <p class="text-slate-600">
              Your feedback may be featured on our site after a quick review. Thank you for taking the time!
            </p>
          </div>

          <%= simple_form_for @testimonial, html: { class: "space-y-6", multipart: true } do |f| %>
            <% if @testimonial.errors.any? %>
              <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3">
                <p class="text-red-800 text-sm font-medium mb-2">Please fix the following:</p>
                <ul class="list-disc list-inside text-red-700 text-sm space-y-1">
                  <% @testimonial.errors.full_messages.each do |msg| %>
                    <li><%= msg %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <%= f.input :name,
                            required: true,
                            label: "Your Name",
                            input_html: {
                              class: "w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all duration-200 text-slate-900"
                            },
                            label_html: { class: "block text-sm font-medium text-slate-700 mb-2" },
                            wrapper_html: { class: "mb-0" },
                            error_html: { class: "text-red-600 text-sm mt-1" } %>
              </div>
              <div>
                <%= f.input :company,
                            required: false,
                            label: "Company",
                            input_html: {
                              class: "w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all duration-200 text-slate-900"
                            },
                            label_html: { class: "block text-sm font-medium text-slate-700 mb-2" },
                            wrapper_html: { class: "mb-0" } %>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <%= f.input :title,
                            required: false,
                            label: "Your Title / Role",
                            input_html: {
                              placeholder: "e.g. Founder, Marketing Director",
                              class: "w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all duration-200 text-slate-900"
                            },
                            label_html: { class: "block text-sm font-medium text-slate-700 mb-2" },
                            wrapper_html: { class: "mb-0" } %>
              </div>
              <div>
                <%= f.input :website_url,
                            required: false,
                            label: "Project / Website URL",
                            input_html: {
                              placeholder: "https://",
                              class: "w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all duration-200 text-slate-900"
                            },
                            label_html: { class: "block text-sm font-medium text-slate-700 mb-2" },
                            wrapper_html: { class: "mb-0" } %>
              </div>
            </div>

            <!-- Star Rating -->
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">Rating</label>
              <div class="flex items-center gap-1" id="star-rating">
                <% (1..5).each do |i| %>
                  <button type="button" data-rating="<%= i %>" class="star-btn text-slate-300 hover:text-amber-400 transition-colors focus:outline-none">
                    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  </button>
                <% end %>
              </div>
              <%= f.hidden_field :rating, id: "testimonial_rating_hidden" %>
            </div>

            <div>
              <%= f.input :blurb,
                          as: :text,
                          required: true,
                          label: "Your Experience",
                          input_html: {
                            rows: 5,
                            placeholder: "What was it like working with Linchpin Industries? What did we build together?",
                            class: "w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all duration-200 text-slate-900"
                          },
                          label_html: { class: "block text-sm font-medium text-slate-700 mb-2" },
                          wrapper_html: { class: "mb-0" },
                          error_html: { class: "text-red-600 text-sm mt-1" } %>
            </div>

            <!-- Photo Upload -->
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">Photos <span class="text-slate-400 font-normal">(optional)</span></label>
              <div class="border-2 border-dashed border-slate-300 rounded-lg p-6 text-center hover:border-slate-400 transition-colors" id="photo-drop-zone">
                <svg class="w-10 h-10 text-slate-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <p class="text-sm text-slate-600 mb-1">Upload screenshots, photos, or anything relevant</p>
                <p class="text-xs text-slate-400 mb-3">PNG, JPG, or WebP up to 5MB each</p>
                <%= f.file_field :photos, multiple: true, accept: "image/png,image/jpeg,image/webp", class: "hidden", id: "photo-input" %>
                <button type="button" onclick="document.getElementById('photo-input').click()" class="btn-secondary text-sm">
                  Choose Files
                </button>
              </div>
              <div id="photo-previews" class="flex flex-wrap gap-3 mt-3"></div>
            </div>

            <%= recaptcha_v3(action: 'testimonial', site_key: ENV['RECAPTCHA_SITE_KEY']) %>

            <div class="text-center">
              <%= f.button :submit, "Share My Feedback", class: "btn-primary text-lg px-8 py-4" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </section>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Star rating
    const stars = document.querySelectorAll('.star-btn');
    const ratingInput = document.getElementById('testimonial_rating_hidden');
    let currentRating = 0;

    stars.forEach(function(star) {
      star.addEventListener('click', function() {
        currentRating = parseInt(this.dataset.rating);
        ratingInput.value = currentRating;
        updateStars();
      });

      star.addEventListener('mouseenter', function() {
        highlightStars(parseInt(this.dataset.rating));
      });

      star.addEventListener('mouseleave', function() {
        highlightStars(currentRating);
      });
    });

    function highlightStars(count) {
      stars.forEach(function(s, i) {
        s.classList.toggle('text-amber-400', i < count);
        s.classList.toggle('text-slate-300', i >= count);
      });
    }

    function updateStars() {
      highlightStars(currentRating);
    }

    // Photo preview
    var photoInput = document.getElementById('photo-input');
    var previews = document.getElementById('photo-previews');

    if (photoInput) {
      photoInput.addEventListener('change', function() {
        previews.innerHTML = '';
        Array.from(this.files).forEach(function(file) {
          var reader = new FileReader();
          reader.onload = function(e) {
            var div = document.createElement('div');
            div.className = 'relative w-20 h-20 rounded-lg overflow-hidden border border-slate-200';
            div.innerHTML = '<img src="' + e.target.result + '" class="w-full h-full object-cover" />';
            previews.appendChild(div);
          };
          reader.readAsDataURL(file);
        });
      });
    }
  });
</script>
